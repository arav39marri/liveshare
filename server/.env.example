PORT=5000

# Allowed client origins (comma-free individual vars, used for CORS allowlist)
CLIENT_ORIGIN1=http://localhost:5173
CLIENT_ORIGIN2=
CLIENT_ORIGIN3=

# Legacy single-origin var (kept for compatibility; current server reads CLIENT_ORIGIN1..3)
CLIENT_ORIGIN=http://localhost:5173

# OTP / room TTL
OTP_TTL_HOURS=24

# Cleanup job
CLEANUP_CRON=*/15 * * * *
CLEANUP_KEY=change_me

# Firebase Admin (required after migration)
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Client -> Server API base (used by Vite client via import.meta.env)
VITE_API_BASE_URL=http://localhost:5000

# --- Legacy (no longer used after Firebase migration) ---
MONGODB_URI=mongodb://127.0.0.1:27017/fileshar
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
